# Environment configuration for the Dataspace Simulator
# Copy this file to .env and adjust values as needed

# Ports (designed to not conflict with participant app which uses 3000, 3002, 3030)
# Frontend:  http://localhost:4000
# Backend:   http://localhost:4001
# Fuseki UI: http://localhost:4030

# Fuseki
FUSEKI_ADMIN_PASSWORD=admin
FUSEKI_DATASET=simulator

# Backend behaviour
AUTO_ACCEPT_NEGOTIATIONS=true
HEARTBEAT_TIMEOUT_MS=120000
